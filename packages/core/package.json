{
  "name": "@sp-treeview/core",
  "version": "4.0.0",
  "description": "Zero-dependency headless state engine for tree views: data projection, cascade/indeterminate selection, lazy loading, filtering. Renders nothing — bring any UI.",
  "keywords": [
    "tree",
    "treeview",
    "tree-view",
    "headless",
    "state",
    "checkbox",
    "cascade",
    "lazy-loading",
    "typescript"
  ],
  "license": "MIT",
  "author": "Srajan Pathak <srajanpathak45@gmail.com> (https://srjn45.github.io/)",
  "homepage": "https://srjn45.github.io/sp-treeview-v2/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srjn45/sp-treeview-v2.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/srjn45/sp-treeview-v2/issues"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "~5.9.0",
    "vitest": "^3.0.0"
  }
}
